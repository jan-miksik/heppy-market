# ── Initia-web environment variables ──────────────────────────────────────────
# Copy to .env.local for local overrides. Set as Cloudflare Pages env vars for production.

# Backend API URL (Cloudflare Worker)
# Local: http://localhost:8787
# Production: https://something-in-loop-api.<your-subdomain>.workers.dev
VITE_API_BASE=http://localhost:8787

# Initia rollup endpoints
# For local demo: keep as localhost (requires running rollup locally)
# For public demo: use ngrok/cloudflare tunnel URL exposing the rollup
VITE_EVM_RPC=http://localhost:8545
VITE_REST_URL=http://localhost:1317
VITE_RPC_URL=http://localhost:26657
VITE_INDEXER_URL=http://localhost:8080

# Rollup native denom (from ~/.minitia/artifacts/config.json -> l2_config.denom)
VITE_NATIVE_DENOM=GAS

# Interwoven bridge defaults
# Source should be Initia L1 testnet for hackathon flows.
VITE_BRIDGE_SRC_CHAIN_ID=initiation-2
VITE_BRIDGE_SRC_DENOM=uinit

# Agent.sol contract address (already deployed to pillow-rollup)
VITE_CONTRACT_ADDRESS=0x286D7241779329DB8c34995d3e8D3796e0d685D7
